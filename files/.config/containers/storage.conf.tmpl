{{ $s := output "sops" "-d" (joinPath .sourceDir "secrets.enc.yaml") | fromYaml -}}
{{ $containers := index $s "containers" -}}
[storage]
driver = "btrfs"
{{- if and (hasKey $containers .hostname) (hasKey (index $containers .hostname) "graphroot") }}
graphroot = "{{ index $containers .hostname "graphroot" | replace "$USER" .username -}}"
{{- end }}
