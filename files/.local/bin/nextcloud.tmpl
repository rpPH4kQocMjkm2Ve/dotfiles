#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

{{ $s := output "sops" "-d" (joinPath .sourceDir "secrets.enc.yaml") | fromYaml -}}
SYNC_DIR="{{ index $s "nextcloud" "sync_dir" }}"

A=()
bwrap_gui_setup A yes
bwrap_dbus_system A

bwrap_bind_dir A \
    "${HOME}/.config/Nextcloud" \
    "${HOME}/.local/share/Nextcloud" \
    "${HOME}/.cache/Nextcloud" \
    "${SYNC_DIR}"

[[ -d "${XDG_RUNTIME_DIR}/keyring" ]] && \
    A+=(--ro-bind "${XDG_RUNTIME_DIR}/keyring" "${XDG_RUNTIME_DIR}/keyring")

bwrap_dbus_common A \
    --talk=org.freedesktop.secrets \
    --talk=org.kde.kwalletd5 \
    --talk=org.kde.kwalletd6

A+=(--setenv QT_QPA_PLATFORMTHEME qt6ct)
bwrap_gui_finish A wayland yes default none

bwrap_exec "${A[@]}" -- /usr/bin/nextcloud "$@"
