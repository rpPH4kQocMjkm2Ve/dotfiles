#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

A=()
bwrap_gui_setup A yes
bwrap_dbus_system A

# Camera
for dev in /dev/video*; do
    [[ -e "$dev" ]] && A+=(--dev-bind "$dev" "$dev")
done
:

bwrap_bind_dir A "${HOME}/.config/obs-studio" "${HOME}/Videos"
bwrap_audio A
A+=(--setenv QT_QPA_PLATFORMTHEME qt6ct)
bwrap_gui_finish A wayland yes

exec bwrap "${A[@]}" -- /usr/bin/obs "$@"
