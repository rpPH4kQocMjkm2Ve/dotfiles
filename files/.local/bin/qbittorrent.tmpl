#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

{{ $s := output "sops" "-d" (joinPath .sourceDir "secrets.enc.yaml") | fromYaml -}}
{{ $host := .hostname -}}
{{ $qbt := index $s "qbittorrent" -}}
DATA_BINDS=()
{{ if hasKey $qbt $host -}}
{{ range $key, $path := index $qbt $host -}}
mkdir -p "{{ $path }}"
DATA_BINDS+=(--bind "{{ $path }}" "{{ $path }}")
{{ end -}}
{{ end -}}

A=()
bwrap_gui_setup A yes
bwrap_dbus_system A
bwrap_bind_dir A \
    "${HOME}/.config/qBittorrent" \
    "${HOME}/.local/share/qBittorrent" \
    "${HOME}/.cache/qBittorrent" \
    "${HOME}/Downloads"
A+=("${DATA_BINDS[@]}")
A+=(--setenv QT_QPA_PLATFORMTHEME qt6ct)
bwrap_gui_finish A wayland yes

exec bwrap "${A[@]}" -- /usr/bin/qbittorrent "$@"
