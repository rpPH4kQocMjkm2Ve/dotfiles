#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

FILE_BINDS=(); ARGS=()
bwrap_resolve_files FILE_BINDS ARGS --bind "$@"

A=()
bwrap_gui_setup A
bwrap_bind_dir A \
    "${HOME}/.config/GIMP" \
    "${HOME}/.local/share/GIMP" \
    "${HOME}/.cache/GIMP" \
    "${HOME}/Pictures" \
    "${HOME}/Downloads"
A+=("${FILE_BINDS[@]}")
bwrap_gui_finish A

exec bwrap "${A[@]}" -- /usr/bin/gimp "${ARGS[@]}"
