#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

{{ $s := output "sops" "-d" (joinPath .chezmoi.sourceDir "secrets.enc.yaml") | fromYaml -}}
MEDIA_DIR="{{ index $s "subs2srs" "media_dir" }}"

CONF_DIR="${HOME}/.config/subs2srs"
LOG_DIR="${HOME}/.local/share/subs2srs"
OUTPUT_DIR="${HOME}/subs2srs"

mkdir -p "$CONF_DIR"

A=()
bwrap_gui_setup A

bwrap_bind_dir A "$CONF_DIR" "$OUTPUT_DIR" "$LOG_DIR"
bwrap_ro_bind_dir A "$MEDIA_DIR"

bwrap_audio A
bwrap_fcitx A

A+=(--chdir "$CONF_DIR")

bwrap_gtk_theme_env A
bwrap_gui_finish A wayland no

exec bwrap "${A[@]}" -- /usr/bin/subs2srs "$@"
