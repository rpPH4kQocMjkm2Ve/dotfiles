#!/usr/bin/env bash
set -euo pipefail
_src() { local p; p=$(verify-lib "$1" "$2") && . "$p" || exit 1; }
_src /usr/lib/bwrap-common/bwrap-common.sh /usr/lib/bwrap-common/

FILE_BINDS=(); ARGS=()
bwrap_resolve_files FILE_BINDS ARGS --ro-bind "$@"

A=()
bwrap_gui_setup A
bwrap_dbus_system A
bwrap_bind_dir A "${HOME}/Pictures/Screenshots"
A+=(--ro-bind-try "${HOME}/.config/swappy" "${HOME}/.config/swappy"
    "${FILE_BINDS[@]}")
bwrap_gui_finish A

exec bwrap "${A[@]}" -- /usr/bin/swappy "${ARGS[@]}"
