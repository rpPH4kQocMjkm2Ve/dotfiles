#!/bin/bash
# Extract Japanese audio track from video files as opus.
# Usage: ffmpeg_jp [-j N] [-i N] <file|directory>...
#   -j N  encode parallelism (default: nproc)
#   -i N  I/O parallelism for demux (default: 2)

set -euo pipefail

JOBS=$(nproc 2>/dev/null || echo 4)
IO_JOBS=2

while getopts "j:i:" opt; do
    case $opt in
        j) JOBS="$OPTARG" ;;
        i) IO_JOBS="$OPTARG" ;;
        *) echo "Usage: $0 [-j N] [-i N] <file|directory>..." >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

find_japanese_track() {
    local input="$1"
    local index lang title
    while IFS=, read -r index lang title; do
        if [[ "$lang" == "ja" || "$lang" == "jpn" ||
              "$title" =~ [Jj]apanese || "$title" =~ 日本語 ]]; then
            echo "$index"
            return 0
        fi
    done < <(ffprobe -v error -select_streams a \
        -show_entries stream=index:stream_tags=language:stream_tags=title \
        -of csv=p=0 "$input")
    echo "-1"
}

run_pool() {
    local max_jobs="$1"; shift
    local active=0
    for cmd in "$@"; do
        while ((active >= max_jobs)); do
            wait -n 2>/dev/null || true
            active=$((active - 1))
        done
        eval "$cmd" &
        active=$((active + 1))
    done
    while ((active > 0)); do
        wait -n 2>/dev/null || true
        active=$((active - 1))
    done
}

# --- collect files ---
files=()
if [[ -n "${LF_SELECTED_FILES:-}" ]]; then
    while IFS= read -r f; do
        [[ -f "$f" ]] && files+=("$f")
    done <<< "$LF_SELECTED_FILES"
elif [[ "$#" -gt 0 ]]; then
    for arg in "$@"; do
        if [[ -f "$arg" ]]; then
            files+=("$arg")
        elif [[ -d "$arg" ]]; then
            while IFS= read -r f; do
                files+=("$f")
            done < <(find "$arg" -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' \))
        else
            echo "ERROR: invalid path: $arg" >&2
        fi
    done
else
    echo "Usage: $0 [-j N] [-i N] <file|directory>..." >&2
    exit 1
fi

# --- scan: find tracks, filter skips ---
declare -A track_map
to_process=()
for f in "${files[@]}"; do
    name=$(basename "$f")
    if [[ -f "${f%.*}.opus" ]]; then
        echo "SKIP: $name"
        continue
    fi
    track=$(find_japanese_track "$f")
    if [[ "$track" -eq -1 ]]; then
        count=$(ffprobe -v error -select_streams a \
            -show_entries stream=index -of csv=p=0 "$f" | wc -l)
        if [[ "$count" -eq 1 ]]; then
            track=$(ffprobe -v error -select_streams a \
                -show_entries stream=index -of csv=p=0 "$f")
        else
            echo "FAIL: no Japanese track in $name"
            continue
        fi
    fi
    track_map["$f"]="$track"
    to_process+=("$f")
done

if [[ ${#to_process[@]} -eq 0 ]]; then
    echo "Nothing to do."
    exit 0
fi

total=${#to_process[@]}
echo "Processing $total files (extract: ${IO_JOBS}j, encode: ${JOBS}j)"

# cleanup temp files on exit/interrupt
cleanup() {
    for f in "${to_process[@]}"; do
        rm -f "${f%.*}.tmp.mka"
    done
}
trap cleanup EXIT

# --- phase 1: demux audio (I/O bound, low parallelism) ---
echo "--- Extracting audio (${IO_JOBS}j) ---"
active=0
for f in "${to_process[@]}"; do
    while ((active >= IO_JOBS)); do
        wait -n 2>/dev/null || true
        active=$((active - 1))
    done
    (
        tmp="${f%.*}.tmp.mka"
        echo "READ: $(basename "$f") [track ${track_map[$f]}]"
        ffmpeg -nostdin -i "$f" -map "0:${track_map[$f]}" -c:a copy -v error "$tmp"
    ) &
    active=$((active + 1))
done
while ((active > 0)); do
    wait -n 2>/dev/null || true
    active=$((active - 1))
done

# --- phase 2: encode opus (CPU bound, high parallelism) ---
echo "--- Encoding opus (${JOBS}j) ---"
active=0
for f in "${to_process[@]}"; do
    tmp="${f%.*}.tmp.mka"
    output="${f%.*}.opus"
    [[ -f "$tmp" ]] || continue
    while ((active >= JOBS)); do
        wait -n 2>/dev/null || true
        active=$((active - 1))
    done
    (
        name=$(basename "$f")
        if ffmpeg -nostdin -i "$tmp" -c:a libopus -b:a 96k -v error "$output"; then
            echo "  OK: $name"
        else
            echo "FAIL: $name"
            rm -f "$output"
        fi
        rm -f "$tmp"
    ) &
    active=$((active + 1))
done
while ((active > 0)); do
    wait -n 2>/dev/null || true
    active=$((active - 1))
done

echo "Done: $total files"
