#!/bin/bash
# Extract Japanese audio track from video files as opus.
# Usage: ffmpeg_jp [-j N] <file|directory>...

set -euo pipefail

JOBS=$(nproc 2>/dev/null || echo 4)

while getopts "j:" opt; do
    case $opt in
        j) JOBS="$OPTARG" ;;
        *) echo "Usage: $0 [-j N] <file|directory>..." >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

# Single ffprobe call per file: get all audio stream info at once
find_japanese_track() {
    local input="$1"
    local first_index=""
    local count=0
    local index lang title
    while IFS=, read -r index lang title; do
        [[ -z "$index" ]] && continue
        ((count++)) || true
        [[ -z "$first_index" ]] && first_index="$index"
        if [[ "$lang" == "ja" || "$lang" == "jpn" ||
              "$title" =~ [Jj]apanese || "$title" =~ 日本語 ]]; then
            echo "$index"
            return 0
        fi
    done < <(ffprobe -v error -select_streams a \
        -show_entries stream=index:stream_tags=language:stream_tags=title \
        -of csv=p=0 "$input")
    # Fallback: single audio track → use it
    if [[ "$count" -eq 1 && -n "$first_index" ]]; then
        echo "$first_index"
        return 0
    fi
    echo "-1"
}

# --- collect files ---
files=()
if [[ -n "${LF_SELECTED_FILES:-}" ]]; then
    while IFS= read -r f; do
        [[ -f "$f" ]] && files+=("$f")
    done <<< "$LF_SELECTED_FILES"
elif [[ "$#" -gt 0 ]]; then
    for arg in "$@"; do
        if [[ -f "$arg" ]]; then
            files+=("$arg")
        elif [[ -d "$arg" ]]; then
            while IFS= read -r f; do
                files+=("$f")
            done < <(find "$arg" -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' \) | sort)
        else
            echo "ERROR: invalid path: $arg" >&2
        fi
    done
else
    echo "Usage: $0 [-j N] <file|directory>..." >&2
    exit 1
fi

# --- scan and build work list ---
declare -A track_map
to_process=()
for f in "${files[@]}"; do
    name=$(basename "$f")
    if [[ -f "${f%.*}.opus" ]]; then
        echo "SKIP: $name"
        continue
    fi
    track=$(find_japanese_track "$f")
    if [[ "$track" -eq -1 ]]; then
        echo "FAIL: no Japanese track in $name"
        continue
    fi
    track_map["$f"]="$track"
    to_process+=("$f")
done

if [[ ${#to_process[@]} -eq 0 ]]; then
    echo "Nothing to do."
    exit 0
fi

total=${#to_process[@]}
echo "Processing $total files (${JOBS}j)"

# --- single-pass: demux + encode in one ffmpeg call ---
active=0
done_count=0
for f in "${to_process[@]}"; do
    while ((active >= JOBS)); do
        wait -n 2>/dev/null || true
        active=$((active - 1))
    done
    (
        name=$(basename "$f")
        output="${f%.*}.opus"
        if ffmpeg -nostdin -v error \
            -i "$f" -map "0:${track_map[$f]}" \
            -c:a libopus -b:a 96k -vn \
            "$output"; then
            echo "  OK: $name"
        else
            echo "FAIL: $name"
            rm -f "$output"
        fi
    ) &
    active=$((active + 1))
done
wait

echo "Done: $total files"
