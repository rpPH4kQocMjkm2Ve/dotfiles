#!/bin/bash

set -e

# ─── Config ───
REPO_NAME="custom"
REPO_DIR="/var/cache/pacman/${REPO_NAME}"

GITPKG_PRIMARY="https://gitlab.com/fkzys"
GITPKG_FALLBACK="https://github.com/rpPH4kQocMjkm2Ve"

# ─── Bootstrap aurutils ───
echo "Checking aurutils..."
if ! command -v aur &> /dev/null; then
    echo "aurutils not found. Installing..."
    sudo pacman -S --needed base-devel git
    BOOTSTRAP_DIR=$(mktemp -d)
    git clone https://aur.archlinux.org/aurutils.git "$BOOTSTRAP_DIR/aurutils"
    cd "$BOOTSTRAP_DIR/aurutils"
    makepkg -si --noconfirm
    cd -
    rm -rf "$BOOTSTRAP_DIR"
fi

# ─── Bootstrap local repo (runs once, self-heals if cache is lost) ───
if [[ ! -f "${REPO_DIR}/${REPO_NAME}.db.tar.gz" ]]; then
    echo "Creating local AUR repository at ${REPO_DIR}..."
    sudo install -d "$REPO_DIR" -o "$(whoami)"
    repo-add "${REPO_DIR}/${REPO_NAME}.db.tar.gz"
fi

# ─── Bootstrap gitpkg ───
echo "Checking gitpkg..."
if ! command -v gitpkg &> /dev/null; then
    echo "gitpkg not found. Bootstrapping..."
    BOOTSTRAP_DIR=$(mktemp -d)
    git clone "${GITPKG_PRIMARY}/gitpkg.git" "$BOOTSTRAP_DIR" 2>/dev/null || \
        git clone "${GITPKG_FALLBACK}/gitpkg.git" "$BOOTSTRAP_DIR"
    cd "$BOOTSTRAP_DIR"
    sudo make install
    cd -
    rm -rf "$BOOTSTRAP_DIR"
fi

